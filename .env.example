# Which platform: "ctfd" or "htb"
PLATFORM=htb

# CTFd (when PLATFORM=ctfd)
CTFD_URL=
CTFD_TOKEN=

# Hack The Box (when PLATFORM=htb)
# Generate the MCP token from HTB Profile Settings -> MCP Access.
# The HTB CTF event id is the numeric id of the event you joined.
HTB_TOKEN=

HTB_MCP_URL=
HTB_EVENT_ID=

# API Keys (at least one required)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
